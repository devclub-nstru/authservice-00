  },
  "homepage": "https://github.com/ABUDIYAAAA/authservice-00#readme",
  "dependencies": {
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  }
}
