APP_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/authservice
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:3001
API_BASE_URL=http://localhost:3000

ACCESS_TOKEN_PRIVATE_KEY_PATH=./keys/access-private.pem
ACCESS_TOKEN_PUBLIC_KEY_PATH=./keys/access-public.pem
REFRESH_TOKEN_PRIVATE_KEY_PATH=./keys/refresh-private.pem
REFRESH_TOKEN_PUBLIC_KEY_PATH=./keys/refresh-public.pem
OAUTH_CLIENT_SECRET_ENCRYPTION_KEY=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/oauth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/oauth/github/callback

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
SESSION_TTL_DAYS=7
BCRYPT_SALT_ROUNDS=10